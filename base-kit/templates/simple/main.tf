    ║                                                                   ║
    ║  Network: ${local.is_host ? "HOST MODE (bridge unavailable)" : "Bridge (isolated Docker networks)"}${local.is_host ? "                       " : "         "}║
    ║                                                                   ║
    ║  LAYER 1 (Foundation):                                             ║
    ║    ${var.enable_pocketid ? "✓" : "✗"} Pocket ID   → ${local.proto}://${local.domains.id}       ║
