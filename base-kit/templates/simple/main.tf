  }

  ports {
    internal = 443
    external = 443
    protocol = "tcp"
  }

  ports {
    internal = 8080
    external = 8080
    protocol = "tcp"
  }

  network_mode = local.is_host ? "host" : null

  dynamic "networks_advanced" {
    for_each = local.is_host ? [] : [1]
