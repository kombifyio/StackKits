  healthcheck {
    test         = ["CMD-SHELL", "curl -s -o /dev/null -w '%%{http_code}' http://localhost:${local.is_host ? local.host_ports.dokploy : 3000}/api/settings | grep -qE '^[2-4]'"]
    interval     = "30s"
