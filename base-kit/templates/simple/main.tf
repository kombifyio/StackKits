    for_each = (!local.is_host && !local.rp_standalone) ? [1] : []
    content {
      name = local.routing_network
    }
  }

  entrypoint = ["stackkit-server"]

  command = [
    "--port",
    "8082",
    "--base-dir",
    "/workspace",
    "--allow-unauthenticated",
