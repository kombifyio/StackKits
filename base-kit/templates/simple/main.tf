          - immich-internal
        environment:
          - POSTGRES_USER=immich
          - POSTGRES_PASSWORD=${random_password.immich_db[0].result}
          - POSTGRES_DB=immich
        volumes:
          - immich-postgres-data:/var/lib/postgresql/data
