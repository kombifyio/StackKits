{
  "id": "SK-S2",
  "name": "Cloud OneClick kombify.me",
  "stage": "live",
  "liveGate": "sim-installer-kombify-me",
  "stackSpec": {
    "name": "sk-s2-cloud-kombify-me",
    "stackkit": "base-kit",
    "mode": "simple",
    "context": "cloud",
    "domain": "kombify.me",
    "subdomainPrefix": "sh-scenario-s2",
    "paas": "komodo",
    "owner": {
      "bootstrapMode": "auto",
      "source": "cloud",
      "recoveryMaterialRef": "techstack://recovery/scenarios/sk-s2"
    },
    "network": {
      "mode": "public"
    },
    "compute": {
      "tier": "standard"
    }
  },
  "env": {
    "requiredKeys": [
      "KOMBIFY_API_KEY",
      "KOMBIFY_USER_EMAIL"
    ],
    "optionalKeys": [
      "STACKKIT_SCENARIO_OUTPUT"
    ]
  },
  "expected": {
    "generation": {
      "context": "cloud",
      "domain": "kombify.me",
      "paas": "komodo",
      "reverseProxyBackend": "stackkit",
      "enableHTTPS": false,
      "stepCAEnabled": true,
      "enableKombifyPoint": false,
      "adminEmail": "tester@kombify.pro",
      "serviceFlags": {
        "enable_dashboard": true,
        "enable_tinyauth": true,
        "enable_pocketid": true,
        "enable_coolify": false,
        "enable_komodo": true,
        "enable_dokploy": false,
        "enable_dokploy_apps": false,
        "enable_traefik": true,
        "enable_uptime_kuma": true,
        "enable_whoami": true,
        "enable_vaultwarden": true,
        "enable_jellyfin": false,
        "enable_immich": true
      }
    },
    "access": {
      "hubUrl": "https://sh-scenario-s2-base.kombify.me",
      "browserUrlMode": "public",
      "services": [
        {"key": "base", "host": "sh-scenario-s2-base.kombify.me", "scheme": "https"},
        {"key": "home", "host": "sh-scenario-s2-home.kombify.me", "scheme": "https"},
        {"key": "auth", "host": "sh-scenario-s2-auth.kombify.me", "scheme": "https"},
        {"key": "id", "host": "sh-scenario-s2-id.kombify.me", "scheme": "https"},
        {"key": "traefik", "host": "sh-scenario-s2-traefik.kombify.me", "scheme": "https"},
        {"key": "komodo", "host": "sh-scenario-s2-komodo.kombify.me", "scheme": "https"},
        {"key": "kuma", "host": "sh-scenario-s2-kuma.kombify.me", "scheme": "https"},
        {"key": "whoami", "host": "sh-scenario-s2-whoami.kombify.me", "scheme": "https"},
        {"key": "vault", "host": "sh-scenario-s2-vault.kombify.me", "scheme": "https"},
        {"key": "photos", "host": "sh-scenario-s2-photos.kombify.me", "scheme": "https"}
      ]
    }
  }
}
