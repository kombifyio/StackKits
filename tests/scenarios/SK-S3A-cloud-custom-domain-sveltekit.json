{
  "id": "SK-S3A",
  "name": "Cloud Custom Domain + SvelteKit App",
  "stage": "gated-live",
  "liveGate": "cloudflare-custom-domain-sveltekit",
  "stackSpec": {
    "name": "sk-s3a-cloud-custom-domain-sveltekit",
    "stackkit": "base-kit",
    "mode": "simple",
    "context": "cloud",
    "domain": "sk-svelte-test.kombify.pro",
    "email": "owner@kombify.pro",
    "adminEmail": "owner@kombify.pro",
    "network": {
      "mode": "public"
    },
    "compute": {
      "tier": "standard"
    },
    "tls": {
      "provider": "cloudflare",
      "challenge": "dns"
    },
    "paas": "coolify",
    "apps": {
      "web": {
        "kind": "sveltekit",
        "image": "ghcr.io/kombifyio/stackkits-smoke-sveltekit:0.1.0",
        "port": 3000,
        "route": {
          "auth": "public"
        },
        "health": {
          "path": "/health"
        },
        "env": {
          "PUBLIC_APP_NAME": "StackKit Smoke"
        }
      }
    }
  },
  "env": {
    "requiredKeys": [
      "STACKKIT_DNS_PROVIDER",
      "STACKKIT_DNS_ZONE",
      "STACKKIT_DNS_TOKEN",
      "STACKKIT_CUSTOM_DOMAIN_BASE"
    ],
    "optionalKeys": [
      "STACKKIT_SCENARIO_OUTPUT"
    ]
  },
  "expected": {
    "generation": {
      "context": "cloud",
      "domain": "sk-svelte-test.kombify.pro",
      "paas": "coolify",
      "reverseProxyBackend": "coolify",
      "enableHTTPS": true,
      "stepCAEnabled": false,
      "enableKombifyPoint": false,
      "adminEmail": "owner@kombify.pro",
      "acmeChallenge": "dns",
      "dnsProvider": "cloudflare",
      "serviceFlags": {
        "enable_dashboard": true,
        "enable_tinyauth": true,
        "enable_pocketid": true,
        "enable_coolify": true,
        "enable_dokploy": false
      }
    },
    "access": {
      "hubUrl": "https://base.sk-svelte-test.kombify.pro",
      "browserUrlMode": "public",
      "services": [
        {"key": "base", "host": "base.sk-svelte-test.kombify.pro", "scheme": "https"},
        {"key": "auth", "host": "auth.sk-svelte-test.kombify.pro", "scheme": "https"},
        {"key": "id", "host": "id.sk-svelte-test.kombify.pro", "scheme": "https"},
        {"key": "coolify", "host": "coolify.sk-svelte-test.kombify.pro", "scheme": "https"}
      ]
    }
  }
}
