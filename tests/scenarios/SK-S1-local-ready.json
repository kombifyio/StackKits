{
  "id": "SK-S1",
  "name": "Local Ready",
  "stage": "live",
  "liveGate": "fresh-ubuntu-local",
  "stackSpec": {
    "name": "sk-s1-local-ready",
    "stackkit": "base-kit",
    "mode": "simple",
    "context": "local",
    "domain": "home.localhost",
    "network": {
      "mode": "local"
    },
    "compute": {
      "tier": "standard"
    },
    "ssh": {
      "user": "admin",
      "keyPath": "~/.ssh/id_ed25519",
      "port": 22
    },
    "services": {
      "homepage": {"enabled": true},
      "coolify": {"enabled": true},
      "uptime-kuma": {"enabled": true},
      "whoami": {"enabled": true},
      "vaultwarden": {"enabled": true},
      "jellyfin": {"enabled": false},
      "immich": {"enabled": true}
    }
  },
  "env": {
    "optionalKeys": [
      "STACKKIT_FRESH_VM_OUTPUT",
      "STACKKIT_FRESH_VM_KEEP",
      "STACKKIT_FRESH_VM_HTTP_PORT",
      "STACKKIT_FRESH_VM_HTTPS_PORT",
      "STACKKIT_FRESH_VM_DOCKER_CONFIG",
      "STACKKIT_FRESH_VM_DOCKER_CONFIG_JSON"
    ]
  },
  "expected": {
    "generation": {
      "context": "local",
      "domain": "home.localhost",
      "paas": "coolify",
      "reverseProxyBackend": "coolify",
      "enableHTTPS": false,
      "stepCAEnabled": false,
      "enableKombifyPoint": false,
      "adminEmail": "admin@home.localhost",
      "serviceFlags": {
        "enable_dashboard": true,
        "enable_homepage": true,
        "enable_tinyauth": true,
        "enable_pocketid": true,
        "enable_coolify": true,
        "enable_dokploy": false,
        "enable_uptime_kuma": true,
        "enable_whoami": true,
        "enable_vaultwarden": true,
        "enable_jellyfin": false,
        "enable_immich": true
      }
    },
    "access": {
      "hubUrl": "http://base.home.localhost",
      "services": [
        {"key": "base", "host": "base.home.localhost", "scheme": "http"},
        {"key": "home", "host": "home.home.localhost", "scheme": "http"},
        {"key": "auth", "host": "auth.home.localhost", "scheme": "http"},
        {"key": "id", "host": "id.home.localhost", "scheme": "http"},
        {"key": "coolify", "host": "coolify.home.localhost", "scheme": "http"},
        {"key": "kuma", "host": "kuma.home.localhost", "scheme": "http"},
        {"key": "whoami", "host": "whoami.home.localhost", "scheme": "http"},
        {"key": "vault", "host": "vault.home.localhost", "scheme": "http"},
        {"key": "photos", "host": "photos.home.localhost", "scheme": "http"}
      ]
    }
  }
}
