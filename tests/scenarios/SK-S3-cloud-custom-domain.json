{
  "id": "SK-S3",
  "name": "Cloud Custom Domain",
  "stage": "gated-live",
  "liveGate": "cloudflare-custom-domain",
  "stackSpec": {
    "name": "sk-s3-cloud-custom-domain",
    "stackkit": "base-kit",
    "mode": "simple",
    "context": "cloud",
    "domain": "kombify.pro",
    "email": "owner@kombify.pro",
    "adminEmail": "owner@kombify.pro",
    "network": {
      "mode": "public"
    },
    "compute": {
      "tier": "standard"
    },
    "tls": {
      "provider": "cloudflare",
      "challenge": "dns"
    },
    "paas": "coolify"
  },
  "env": {
    "requiredKeys": [
      "STACKKIT_DNS_PROVIDER",
      "STACKKIT_DNS_ZONE",
      "STACKKIT_DNS_TOKEN",
      "STACKKIT_CUSTOM_DOMAIN_BASE"
    ],
    "optionalKeys": [
      "STACKKIT_SCENARIO_OUTPUT"
    ]
  },
  "expected": {
    "generation": {
      "context": "cloud",
      "domain": "kombify.pro",
      "paas": "coolify",
      "reverseProxyBackend": "coolify",
      "enableHTTPS": true,
      "stepCAEnabled": false,
      "enableKombifyPoint": false,
      "adminEmail": "owner@kombify.pro",
      "acmeChallenge": "dns",
      "dnsProvider": "cloudflare",
      "serviceFlags": {
        "enable_dashboard": true,
        "enable_tinyauth": true,
        "enable_pocketid": true,
        "enable_coolify": true,
        "enable_dokploy": false
      }
    },
    "access": {
      "hubUrl": "https://base.kombify.pro",
      "browserUrlMode": "public",
      "services": [
        {"key": "base", "host": "base.kombify.pro", "scheme": "https"},
        {"key": "home", "host": "home.kombify.pro", "scheme": "https"},
        {"key": "auth", "host": "auth.kombify.pro", "scheme": "https"},
        {"key": "id", "host": "id.kombify.pro", "scheme": "https"},
        {"key": "coolify", "host": "coolify.kombify.pro", "scheme": "https"},
        {"key": "kuma", "host": "kuma.kombify.pro", "scheme": "https"},
        {"key": "whoami", "host": "whoami.kombify.pro", "scheme": "https"},
        {"key": "vault", "host": "vault.kombify.pro", "scheme": "https"},
        {"key": "photos", "host": "photos.kombify.pro", "scheme": "https"}
      ]
    }
  }
}
