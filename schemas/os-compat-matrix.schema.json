{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stackkit.cc/schemas/os-compat-matrix.schema.json",
  "title": "StackKit OS compatibility matrix (public v2)",
  "description": "Provider-, device-, runtime-, architecture-, and virtualization-neutral public OS support projection. Positive grades will require current HostConformanceReceipts plus versioned OS support policy after the controlled projector exists. Container/VM/bare-metal diagnostics are not valid inputs.",
  "type": "object",
  "required": ["schemaVersion", "stackkitsVersion", "results", "generatedAt"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "stackkitsVersion": {
      "type": "string",
      "pattern": "^(unreleased|v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?)$"
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/result" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "grade": {
      "const": "unverified",
      "description": "Positive grades stay disabled until the full HostConformanceReceipt projector is implemented."
    },
    "os": {
      "type": "object",
      "required": ["family", "distribution", "version"],
      "properties": {
        "family": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "distribution": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
        "version": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" }
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": ["os", "grade", "reasonCodes"],
      "properties": {
        "os": { "$ref": "#/$defs/os" },
        "grade": { "$ref": "#/$defs/grade" },
        "reasonCodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": ["current-candidate-receipt-pending", "os-policy-not-yet-admitted"]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  }
}
