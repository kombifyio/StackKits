{
  "metadata": {
    "name": "fixture-kit",
    "version": "1.0.0",
    "description": "Stress-test fixture with edge cases that have historically broken canonical hashing across language boundaries",
    "tags": ["roundtrip", "edge-cases"]
  },
  "supportedOS": ["ubuntu-24", "ubuntu-22", "debian-12"],
  "features": {
    "multiNode": false,
    "highAvailability": true,
    "vpnOverlay": false
  },
  "application": {
    "photos": {
      "role": "default",
      "defaultTool": "immich",
      "alternatives": ["ente-photos", "stingle"]
    },
    "media": {
      "role": "default",
      "defaultTool": "jellyfin"
    },
    "Vault": {
      "role": "optional",
      "defaultTool": "vaultwarden"
    }
  },
  "computeTiers": {
    "low":      {"requirements": {"cpu": 2, "memory": 4,  "disk": 10}},
    "standard": {"requirements": {"cpu": 4, "memory": 8,  "disk": 20}},
    "high":     {"requirements": {"cpu": 8, "memory": 16, "disk": 40}}
  },
  "_unicode_keys": {
    "äöü":   "umlauts",
    "中文":   "chinese",
    "🚀":    "emoji"
  },
  "_numeric_string_keys": {
    "1":   "one",
    "10":  "ten",
    "2":   "two",
    "100": "hundred"
  },
  "_nested_arrays": [
    {"name": "first",  "weight": 1.5},
    {"name": "second", "weight": 2.5},
    {"name": "third",  "weight": 3.0}
  ],
  "_special_chars_in_strings": "quotes \"both\" and 'single', backslash \\, newline \\n, tab \\t",
  "_empty_collections": {
    "empty_array":  [],
    "empty_object": {}
  }
}
