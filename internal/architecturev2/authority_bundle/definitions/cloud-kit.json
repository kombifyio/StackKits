{
  "accessDefaults": {
    "deviceBoundSessions": true,
    "deviceEnrollment": "none",
    "lanLocationIsIdentity": false,
    "privilegedStepUpRequired": true,
    "publicRoutesDefaultClosed": true
  },
  "apiVersion": "stackkit/v2alpha1",
  "authoring": {
    "contractVersion": "1.0.0",
    "initialSpec": {
      "apiVersion": "stackkit/v2alpha1",
      "availability": {
        "enabled": false,
        "fencing": "none",
        "mode": "single"
      },
      "capabilities": {
        "disable": [],
        "enable": []
      },
      "container": {
        "dataRoot": "/var/lib/docker",
        "engine": "docker",
        "liveRestore": true,
        "logDriver": "json-file",
        "registryMirrors": [],
        "rootless": false
      },
      "controlPlane": {
        "authoritySiteRef": "cloud",
        "members": [
          "cloud-main"
        ],
        "mode": "single"
      },
      "data": {
        "defaultAuthority": "cloud"
      },
      "generation": {
        "outputRoot": "deploy",
        "strategy": "kit-template",
        "target": "opentofu"
      },
      "install": {
        "mode": "bootstrapped",
        "platform": {
          "fallbackAllowed": false,
          "management": "selected-provider",
          "setupPolicy": {
            "applicationDefault": "on-demand",
            "platform": "automatic"
          }
        },
        "runtime": "docker"
      },
      "kind": "StackSpec",
      "kit": {
        "slug": "cloud-kit"
      },
      "lanDiscovery": {
        "advertiseRouteRefs": []
      },
      "metadata": {
        "name": "my-cloud-homelab"
      },
      "network": {
        "dns": {
          "searchDomains": [],
          "servers": [
            "1.1.1.1",
            "8.8.8.8"
          ]
        },
        "domain": {
          "base": "example.invalid"
        },
        "mode": "public-capable",
        "tls": {
          "defaultMode": "public",
          "minVersion": "TLS1.2"
        },
        "transport": {
          "ipv6": false,
          "mtu": 1500,
          "subnet": "172.20.0.0/16"
        }
      },
      "nodes": [
        {
          "enabled": true,
          "failureDomain": "node-cloud-main",
          "hardware": {
            "arch": "amd64",
            "profile": "standard"
          },
          "id": "cloud-main",
          "roles": [
            "controller",
            "worker",
            "edge"
          ],
          "siteRef": "cloud"
        }
      ],
      "partitionPolicy": {
        "cloudEdge": "fail-closed",
        "denyNewCrossSiteSessions": true,
        "localIdentityAuthorityAvailable": false,
        "maxStaleVerificationSeconds": 0,
        "onCloudLoss": "fail-closed",
        "onLinkLoss": "not-applicable"
      },
      "sites": [
        {
          "failureDomain": "cloud-primary",
          "id": "cloud",
          "kind": "cloud"
        }
      ],
      "source": {
        "kind": "native-v2"
      },
      "storage": {},
      "system": {}
    },
    "initialSpecStatus": "supported",
    "requiredOverrides": [
      "network.domain.base"
    ]
  },
  "availability": {
    "policies": {
      "quorum": {
        "defaults": {
          "failureDomainSpread": 3,
          "fencing": "automatic",
          "rpoSeconds": 15,
          "rtoSeconds": 120
        },
        "evidenceAcceptance": {
          "requiredRefs": [
            "ha-cloud-quorum-failure-domain-majority-proof"
          ]
        },
        "failureModel": {
          "basis": "failure-domain",
          "memberSiteScope": "control-member-sites",
          "partitionBehavior": "failure-domain-failover"
        },
        "healthAcceptance": {
          "memberReadiness": "majority",
          "requiredGateRefs": [
            "provider-stackkits-ha-cloud-quorum-ha-cloud-quorum-contract",
            "module-stackkits-ha-cloud-quorum-runtime-ha-cloud-quorum-contract"
          ]
        },
        "limits": {
          "allowedFencing": [
            "automatic"
          ],
          "maxFailureDomainSpread": 7,
          "maxRpoSeconds": 60,
          "maxRtoSeconds": 300,
          "minFailureDomainSpread": 3
        },
        "mode": "quorum",
        "moduleRef": "stackkits-ha-cloud-quorum-runtime",
        "policyRef": "cloud-ha-quorum-policy",
        "providerRef": "stackkits-ha-cloud-quorum",
        "realizationRef": "cloud-ha-quorum-v1",
        "selector": "control-plane-members"
      },
      "warm-standby": {
        "defaults": {
          "failureDomainSpread": 2,
          "fencing": "automatic",
          "rpoSeconds": 60,
          "rtoSeconds": 300
        },
        "evidenceAcceptance": {
          "requiredRefs": [
            "ha-cloud-warm-standby-failure-domain-proof"
          ]
        },
        "failureModel": {
          "basis": "failure-domain",
          "memberSiteScope": "control-member-sites",
          "partitionBehavior": "failure-domain-failover"
        },
        "healthAcceptance": {
          "memberReadiness": "all",
          "requiredGateRefs": [
            "provider-stackkits-ha-cloud-warm-ha-cloud-warm-contract",
            "module-stackkits-ha-cloud-warm-runtime-ha-cloud-warm-contract"
          ]
        },
        "limits": {
          "allowedFencing": [
            "automatic"
          ],
          "maxFailureDomainSpread": 3,
          "maxRpoSeconds": 300,
          "maxRtoSeconds": 900,
          "minFailureDomainSpread": 2
        },
        "mode": "warm-standby",
        "moduleRef": "stackkits-ha-cloud-warm-runtime",
        "policyRef": "cloud-ha-warm-standby-policy",
        "providerRef": "stackkits-ha-cloud-warm",
        "realizationRef": "cloud-ha-warm-standby-v1",
        "selector": "control-plane-members"
      }
    }
  },
  "bridge": {
    "edgeKinds": [],
    "required": false,
    "sourceKinds": []
  },
  "capabilities": {
    "defaults": [],
    "forbidden": [
      "site-local",
      "lan-discovery",
      "local-ingress",
      "lan-access-policy",
      "device-enrollment-home"
    ],
    "optional": [
      "private-admin-mesh",
      "failure-domain-placement",
      "availability-ha"
    ],
    "required": [
      "topology-core",
      "host-bootstrap",
      "external-host-admission",
      "host-conformance",
      "security-baseline",
      "human-identity-core",
      "device-trust-core",
      "access-policy",
      "runtime-paas",
      "service-catalog",
      "secrets-recovery",
      "storage-data-policy",
      "backup-core",
      "observability-evidence",
      "lifecycle-update",
      "site-cloud",
      "host-local-internet-firewall",
      "public-edge",
      "public-dns",
      "public-tls",
      "internet-host-hardening",
      "remote-owner-bootstrap",
      "offsite-object-backup",
      "cloud-control-authority"
    ]
  },
  "dataDefaults": {
    "authority": "cloud",
    "cloudCopyRequiresPolicy": true
  },
  "deviceEnrollment": {
    "authorityKinds": [],
    "mode": "disabled",
    "required": false
  },
  "evidenceScenarios": [
    "SK-S2",
    "SK-S3"
  ],
  "failureDefaults": {
    "cloudEdgeFailsClosed": true,
    "localServicesSurviveCloudLoss": false,
    "offlineOperation": false
  },
  "generation": {
    "allowedStrategies": [
      "kit-template",
      "module-fragments"
    ],
    "allowedTargets": [
      "opentofu",
      "compose"
    ],
    "contractVersion": "1.0.0",
    "defaultStrategy": "kit-template",
    "defaultTarget": "opentofu"
  },
  "identityTrust": {
    "authorities": [
      {
        "id": "cloud-human-authority",
        "owner": {
          "kind": "catalog",
          "moduleRef": "stackkits-cloud-identity-trust-policy-manifest",
          "providerRef": "stackkits-cloud-identity-trust-policy"
        },
        "placement": {
          "selector": "control-authority-site"
        },
        "principal": "human",
        "trustDomainRef": "cloud-stackkit-trust"
      },
      {
        "id": "owner-device-authority",
        "owner": {
          "contractRef": "owner-bound-device-authority",
          "kind": "external"
        },
        "placement": {
          "contractRef": "owner-bound-device-authority",
          "selector": "external"
        },
        "principal": "device",
        "trustDomainRef": "owner-bound-device-trust"
      },
      {
        "id": "cloud-workload-authority",
        "owner": {
          "kind": "catalog",
          "moduleRef": "stackkits-cloud-identity-trust-policy-manifest",
          "providerRef": "stackkits-cloud-identity-trust-policy"
        },
        "placement": {
          "selector": "control-authority-site"
        },
        "principal": "workload",
        "trustDomainRef": "cloud-stackkit-trust"
      }
    ],
    "credentialIssuers": [
      {
        "audienceRefs": [
          "stackkit-human-session"
        ],
        "authorityRef": "cloud-human-authority",
        "credentialTTLSeconds": 86400,
        "enrollment": {
          "exposure": "none",
          "mode": "none"
        },
        "id": "cloud-human-credential-issuer",
        "issuanceWithinStackKit": true,
        "issuerRef": "cloud-human-issuer",
        "owner": {
          "kind": "catalog",
          "moduleRef": "stackkits-cloud-identity-trust-policy-manifest",
          "providerRef": "stackkits-cloud-identity-trust-policy"
        },
        "placement": {
          "selector": "control-authority-site"
        },
        "principal": "human",
        "proofOfPossessionRequired": false,
        "revocationMaxStalenessSeconds": 0,
        "revocationSupported": true,
        "sessionTTLSeconds": 900,
        "verificationKeySetRef": "cloud-human-verification-keys"
      },
      {
        "audienceRefs": [
          "stackkit-device-session"
        ],
        "authorityRef": "owner-device-authority",
        "credentialTTLSeconds": 3600,
        "enrollment": {
          "exposure": "none",
          "mode": "none"
        },
        "id": "owner-device-credential-issuer",
        "issuanceWithinStackKit": false,
        "issuerRef": "owner-bound-device-issuer",
        "owner": {
          "contractRef": "owner-bound-device-authority",
          "kind": "external"
        },
        "placement": {
          "contractRef": "owner-bound-device-authority",
          "selector": "external"
        },
        "principal": "device",
        "proofOfPossessionRequired": true,
        "revocationMaxStalenessSeconds": 0,
        "revocationSupported": true,
        "sessionTTLSeconds": 900,
        "verificationKeySetRef": "owner-bound-device-verification-keys"
      },
      {
        "audienceRefs": [
          "stackkit-workload"
        ],
        "authorityRef": "cloud-workload-authority",
        "credentialTTLSeconds": 300,
        "enrollment": {
          "exposure": "none",
          "mode": "none"
        },
        "id": "cloud-workload-credential-issuer",
        "issuanceWithinStackKit": true,
        "issuerRef": "cloud-workload-issuer",
        "owner": {
          "kind": "catalog",
          "moduleRef": "stackkits-cloud-identity-trust-policy-manifest",
          "providerRef": "stackkits-cloud-identity-trust-policy"
        },
        "placement": {
          "selector": "control-authority-site"
        },
        "principal": "workload",
        "proofOfPossessionRequired": true,
        "revocationMaxStalenessSeconds": 0,
        "revocationSupported": true,
        "sessionTTLSeconds": 300,
        "verificationKeySetRef": "cloud-workload-verification-keys"
      }
    ],
    "integrity": {
      "authorityIDsUnique": true,
      "distributionIDsUnique": true,
      "distributionIssuers": [],
      "issuerAuthorities": [
        {
          "issuerID": "cloud-human-credential-issuer",
          "matches": [
            "cloud-human-authority"
          ]
        },
        {
          "issuerID": "owner-device-credential-issuer",
          "matches": [
            "owner-device-authority"
          ]
        },
        {
          "issuerID": "cloud-workload-credential-issuer",
          "matches": [
            "cloud-workload-authority"
          ]
        }
      ],
      "issuerIDsUnique": true,
      "issuerRefsUnique": true,
      "issuerVerifiers": [
        {
          "issuerID": "cloud-human-credential-issuer",
          "matches": [
            "cloud-human-verifier"
          ]
        },
        {
          "issuerID": "owner-device-credential-issuer",
          "matches": [
            "cloud-device-verifier"
          ]
        },
        {
          "issuerID": "cloud-workload-credential-issuer",
          "matches": [
            "cloud-workload-verifier"
          ]
        }
      ],
      "verifierIDsUnique": true,
      "verifierIssuers": [
        {
          "audiences": [
            {
              "matches": [
                "stackkit-human-session"
              ],
              "value": "stackkit-human-session"
            }
          ],
          "matches": [
            "cloud-human-credential-issuer"
          ],
          "verifierID": "cloud-human-verifier"
        },
        {
          "audiences": [
            {
              "matches": [
                "stackkit-device-session"
              ],
              "value": "stackkit-device-session"
            }
          ],
          "matches": [
            "owner-device-credential-issuer"
          ],
          "verifierID": "cloud-device-verifier"
        },
        {
          "audiences": [
            {
              "matches": [
                "stackkit-workload"
              ],
              "value": "stackkit-workload"
            }
          ],
          "matches": [
            "cloud-workload-credential-issuer"
          ],
          "verifierID": "cloud-workload-verifier"
        }
      ]
    },
    "verifierDistributions": [],
    "verifierPlacements": [
      {
        "audienceRefs": [
          "stackkit-human-session"
        ],
        "id": "cloud-human-verifier",
        "issuerRef": "cloud-human-issuer",
        "owner": {
          "kind": "catalog",
          "moduleRef": "stackkits-cloud-identity-trust-policy-manifest",
          "providerRef": "stackkits-cloud-identity-trust-policy"
        },
        "placement": {
          "selector": "cloud-sites"
        },
        "principal": "human",
        "proofOfPossessionRequired": false,
        "revocationMaxStalenessSeconds": 0,
        "verificationKeySetRef": "cloud-human-verification-keys"
      },
      {
        "audienceRefs": [
          "stackkit-device-session"
        ],
        "id": "cloud-device-verifier",
        "issuerRef": "owner-bound-device-issuer",
        "owner": {
          "kind": "catalog",
          "moduleRef": "stackkits-cloud-identity-trust-policy-manifest",
          "providerRef": "stackkits-cloud-identity-trust-policy"
        },
        "placement": {
          "selector": "cloud-sites"
        },
        "principal": "device",
        "proofOfPossessionRequired": true,
        "revocationMaxStalenessSeconds": 0,
        "verificationKeySetRef": "owner-bound-device-verification-keys"
      },
      {
        "audienceRefs": [
          "stackkit-workload"
        ],
        "id": "cloud-workload-verifier",
        "issuerRef": "cloud-workload-issuer",
        "owner": {
          "kind": "catalog",
          "moduleRef": "stackkits-cloud-identity-trust-policy-manifest",
          "providerRef": "stackkits-cloud-identity-trust-policy"
        },
        "placement": {
          "selector": "cloud-sites"
        },
        "principal": "workload",
        "proofOfPossessionRequired": true,
        "revocationMaxStalenessSeconds": 0,
        "verificationKeySetRef": "cloud-workload-verification-keys"
      }
    ]
  },
  "kind": "KitDefinition",
  "metadata": {
    "description": "Cloud-only StackKit for one or more externally supplied cloud hosts",
    "displayName": "Cloud Kit",
    "slug": "cloud-kit",
    "version": "5.0.0"
  },
  "network": {
    "defaultTLSMode": "public",
    "domainRequired": true,
    "mode": "public-capable"
  },
  "partitionPolicy": {
    "cloudEdge": "fail-closed",
    "denyNewCrossSiteSessions": true,
    "localIdentityAuthorityAvailable": false,
    "maxStaleVerificationSeconds": 0,
    "onCloudLoss": "fail-closed",
    "onLinkLoss": "not-applicable"
  },
  "reachability": {
    "accessPolicies": {
      "allowedExposures": [
        "private",
        "public"
      ],
      "lanStepDownAllowed": false
    },
    "routes": {
      "local": {
        "allowed": true,
        "allowedOriginKinds": [
          "cloud"
        ],
        "requiredRealizations": []
      },
      "public": {
        "allowed": true,
        "allowedOriginKinds": [
          "cloud"
        ],
        "requiredRealizations": [
          {
            "capabilityRef": "public-edge",
            "role": "edge"
          }
        ]
      },
      "remote-private": {
        "allowed": true,
        "allowedOriginKinds": [
          "cloud"
        ],
        "requiredRealizations": [
          {
            "capabilityRef": "private-admin-mesh",
            "role": "access"
          }
        ]
      }
    }
  },
  "topology": {
    "allowedSiteKinds": [
      "cloud"
    ],
    "controlPlane": {
      "allowedAuthorityKinds": [
        "cloud"
      ],
      "allowedModes": [
        "single",
        "warm-standby",
        "quorum"
      ],
      "defaultMode": "single",
      "memberSiteScope": "any"
    },
    "maxSites": 1,
    "minSites": 1,
    "multiNode": true,
    "requiredSiteKinds": [
      "cloud"
    ]
  },
  "workloads": {
    "defaults": [],
    "forbidden": [],
    "optional": [
      "photos"
    ],
    "required": []
  }
}
