// Package {{.Package}} — {{.DisplayName}} module (scaffolded, draft).
//
// {{.Description}}
//
// Generated by `stackkit module scaffold` from module_facts.json (ADR-0027).
// Deterministic output: edit the facts and re-scaffold; do not hand-diff.
package {{.Package}}

import "github.com/kombifyio/stackkits/base"

Contract: base.#ModuleContract & {
	metadata: {
		name:        {{quote .Slug}}
		displayName: {{quote .DisplayName}}
		version:     {{quote .Version}}
		layer:       {{quote .Layer}}
		description: {{quote .Description}}
		core:        {{.Core}}
		maturity:    "draft"
	}
{{if .Requires}}
	requires: {
{{- if .Requires.HasServices}}
		services: {
{{- range .Requires.Services}}
			{{quote .Name}}: {
{{- if .MinVersion}}
				minVersion: {{quote .MinVersion}}
{{- end}}
{{- if .Provides}}
				provides: [{{range $i, $p := .Provides}}{{if $i}}, {{end}}{{quote $p}}{{end}}]
{{- end}}
{{- if .Optional}}
				optional: true
{{- end}}
			}
{{- end}}
		}
{{- end}}
{{- if .Requires.HasInfra}}
		infrastructure: {
			docker:            {{.Requires.Infrastructure.Docker}}
{{- if .Requires.Infrastructure.Network}}
			network:           {{quote .Requires.Infrastructure.Network}}
{{- end}}
			dockerSocket:      {{.Requires.Infrastructure.DockerSocket}}
			persistentStorage: {{.Requires.Infrastructure.PersistentStorage}}
{{- if .Requires.Infrastructure.MinMemory}}
			minMemory:         {{quote .Requires.Infrastructure.MinMemory}}
{{- end}}
{{- if .Requires.Infrastructure.Arch}}
			arch:              {{quote .Requires.Infrastructure.Arch}}
{{- end}}
		}
{{- end}}
	}
{{end}}
	placementSupport: {
		local_only:         {{.Placement.LocalOnly}}
		standard:           {{.Placement.Standard}}
		managed_serverless: {{.Placement.ManagedServerless}}
	}

	services: {
{{- range .Services}}
		{{quote .Name}}: base.#ServiceDefinition & {
			name:     {{quote .Name}}
			type:     {{quote .Type}}
			image:    {{quote .Image}}
			tag:      {{quote .Tag}}
			required: {{.Required}}
			status:   "implemented"
{{- if .Needs}}
			needs: [{{range $i, $n := .Needs}}{{if $i}}, {{end}}{{quote $n}}{{end}}]
{{- end}}

			network: {
{{- if .Routed}}
				traefik: {
					enabled: true
					rule:    {{quote .TraefikRule}}
					port:    {{.TraefikPort}}
				}
{{- end}}
				networks: [{{range $i, $n := .Networks}}{{if $i}}, {{end}}{{quote $n}}{{end}}]
			}
{{- if .HasAccess}}

			accessPolicy: {
				outerAuth: {{quote .OuterAuth}}
				appAuth:   {{quote .AppAuth}}
			}
{{- end}}
{{- if .Upstream}}

			upstream: {
{{- if .Upstream.HasGitHub}}
				github: {repo: {{quote .Upstream.GitHub}}}
{{- end}}
				registry: {image: {{quote .Upstream.RegistryImage}}}
				track: {{quote .Upstream.Track}}
{{- if .Upstream.PinLine}}
				pinLine: {{quote .Upstream.PinLine}}
{{- end}}
{{- if .Upstream.HasOSV}}
				osv: {ecosystem: {{quote .Upstream.OSVEcosystem}}, name: {{quote .Upstream.OSVName}}}
{{- end}}
			}
{{- end}}
{{- if .Volumes}}

			volumes: [
{{- range .Volumes}}
				{
					source:      {{quote .Source}}
					target:      {{quote .Target}}
					type:        {{quote .Type}}
{{- if .ReadOnly}}
					readOnly:    true
{{- end}}
					backup:      {{.Backup}}
{{- if .Description}}
					description: {{quote .Description}}
{{- end}}
				},
{{- end}}
			]
{{- end}}
{{- if .Environment}}

			environment: {
{{- range .Environment}}
				{{quote .Key}}: {{quote .Value}}
{{- end}}
			}
{{- end}}

			healthCheck: {
				enabled: true
{{- if .HC.HTTP}}
				http: {
					path:   {{quote .HC.Path}}
					port:   {{.HC.Port}}
					scheme: {{quote .HC.Scheme}}
				}
{{- else}}
				command: {{quote .HC.Command}}
{{- end}}
				interval: {{quote .HC.Interval}}
				timeout:  {{quote .HC.Timeout}}
				retries:  {{.HC.Retries}}
			}
{{- if .Resources}}

			resources: {
				memory:    {{quote .Resources.Memory}}
{{- if .Resources.MemoryMax}}
				memoryMax: {{quote .Resources.MemoryMax}}
{{- end}}
{{- if .Resources.CPUs}}
				cpus:      {{.Resources.CPUs}}
{{- end}}
			}
{{- end}}

			security: {
				noNewPrivileges: {{.Security.NoNewPrivileges}}
				capDrop: [{{range $i, $c := .Security.CapDrop}}{{if $i}}, {{end}}{{quote $c}}{{end}}]
{{- if .Security.ReadOnly}}
				readOnly: true
{{- end}}
{{- if .Security.Tmpfs}}
				tmpfs: [{{range $i, $t := .Security.Tmpfs}}{{if $i}}, {{end}}{{quote $t}}{{end}}]
{{- end}}
			}
{{- if .Subdomain}}

			subdomain: {key: {{quote .Subdomain.Key}}, nested: {{quote .Subdomain.Nested}}, flat: {{quote .Subdomain.Flat}}}
{{- end}}

			output: {description: {{quote .OutputDesc}}}
		}
{{- end}}
	}
}
