{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stackkit.cc/schemas/stackkit-agent-functional-result.schema.json",
  "title": "StackKit Agent Functional Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "manifestRef", "checkedModes", "checkedViaAgent", "verificationOutput", "failureClassification", "noHandEditedGeneratedArtifacts"],
  "properties": {
    "status": { "type": "string", "enum": ["pass"] },
    "manifestRef": { "type": "string", "minLength": 1 },
    "checkedModes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "checkedViaAgent": { "type": "boolean", "const": true },
    "verificationOutput": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "status": { "type": "string" },
        "stackkit": { "type": "string" },
        "checks": { "type": "array" }
      }
    },
    "failureClassification": {
      "type": "string",
      "enum": ["none", "host-prerequisite", "docker-daemon", "image-pull", "network-or-dns", "generated-config", "opentofu-plan", "opentofu-apply", "service-health", "unknown"]
    },
    "noHandEditedGeneratedArtifacts": { "type": "boolean", "const": true }
  }
}

