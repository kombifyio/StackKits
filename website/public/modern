#!/bin/sh
# Static website entrypoint for Modern Home Lab.
# Usage: curl -sSL https://modern.stackkit.cc | sh
set -eu
STACKKIT_INSTALL_URL="${STACKKIT_INSTALL_URL:-https://install.stackkit.cc}"
HOMELAB_DIR="${HOMELAB_DIR:-$HOME/modern-homelab}"

printf '\033[1;34m==> %s\033[0m\n' "Installing stackkit CLI + Modern Home Lab definitions"
printf '\033[1;33m%s\033[0m\n' "Modern Home Lab is alpha/scaffolding in this release. Use it for definition preview only; BaseKit is the verified beta one-click path."
curl -sSL "$STACKKIT_INSTALL_URL" | sh -s -- modern-homelab

mkdir -p "$HOMELAB_DIR"
cd "$HOMELAB_DIR"

printf '\033[1;34m==> %s\033[0m\n' "Starting guided init with Modern Home Lab preselected"
stackkit init modern-homelab
